---
/**
 * CaseStudyLayout — wraps every case study page.
 *
 * Page structure (matching the design prototype):
 *   [cream-500]  Nav (light) + case-hero: title + two-column grid (meta | image)
 *   [diagonal]   cream → olive
 *   [olive]      "Final production" h2 + images
 *                "The process" h2 + process diagram + BXT paragraph
 *                ContentSection: Discovery / Define / Results
 *   [diagonal]   olive → cream-light
 *   [cream-300]  Footer (cream variant)
 */
import Nav from '../components/Nav.astro';
import Divider from '../components/Divider.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
import type { CollectionEntry } from 'astro:content';

interface Props {
  entry: CollectionEntry<'projects'>;
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const d = entry.data;

// Meta rows to display — omit undefined fields
const metaSections: { label: string; body: string | string[] }[] = [
  ...(d.roleDetail ? [{ label: 'Role and responsibility', body: [d.roleDetail] }] : [{ label: 'Role', body: [d.role] }]),
  ...(d.description ? [{ label: 'Description', body: [d.description] }] : []),
  ...(d.platform ? [{ label: 'Platform', body: [d.platform] }] : []),
  ...(d.workDone ? [{ label: 'Work done', body: [d.workDone] }] : []),
  ...(d.timeframe ? [{ label: 'Timeframe', body: [d.timeframe] }] : []),
  ...(d.award ? [{ label: 'Awards', body: [d.award] }] : []),
];

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{d.title} — Christopher Teves</title>
    <meta name="description" content={d.description ?? `${d.title} — Case study by Christopher Teves`} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  </head>

  <body class="case-body">

    <!-- ── STICKY NAV — outside header so sticky spans full page ── -->
    <Nav theme="light" />

    <!-- ── CREAM HEADER ─────────────────────────────────────────── -->
    <header class="case-header">

      <section class="case-hero">
        <div class="container">

          <h1 class="case-title">{d.title}</h1>

          <div class="case-grid">
            <!-- Left: meta sections -->
            <div class="case-meta">
              {metaSections.map(section => (
                <div class="case-section">
                  <h3>{section.label}</h3>
                  {Array.isArray(section.body)
                    ? section.body.map((p: string) => <p>{p}</p>)
                    : <p>{section.body}</p>
                  }
                </div>
              ))}
            </div>

            <!-- Right: hero image -->
            <div class="case-mockups">
              {d.heroImage && (
                <div>
                  <img
                    src={d.heroImage}
                    alt={`${d.title} screens`}
                    style="display:block;width:100%;height:auto;"
                  />
                  {d.award && (
                    <div style="margin-top:16px;display:flex;justify-content:center;">
                      <img
                        src="/images/red-dot.png"
                        alt="Red Dot Design Award"
                        style="display:block;width:180px;height:auto;"
                      />
                    </div>
                  )}
                </div>
              )}
            </div>
          </div>

        </div>
      </section>
    </header>

    <!-- ── DIVIDER — cream → olive ──────────────────────────────── -->
    <Divider from="cream" to="olive" direction="left-up" />

    <!-- ── OLIVE BODY ───────────────────────────────────────────── -->
    <section class="section--olive case-olive">
      <div class="container">
        <div class="case-olive-inner">

          <!-- Final production -->
          {d.finalProductionImages && d.finalProductionImages.length > 0 && (
            <div class="delivery-section">
              <h2 class="olive-heading">Final production</h2>
              <div class="delivery-images">
                {d.finalProductionImages.map((src: string, i: number) => (
                  <img
                    src={src}
                    alt={`${d.title} — final production ${i + 1}`}
                    style="display:block;width:100%;height:auto;"
                  />
                ))}
              </div>
            </div>
          )}

          <!-- The process -->
          <div class="process-section">
            <h2 class="olive-heading process-heading">The process</h2>

            {d.processImage && (
              <div style="width:100%;margin-bottom:0;">
                <img
                  src={d.processImage}
                  alt={`${d.title} — process diagram`}
                  style="display:block;width:100%;height:auto;"
                />
              </div>
            )}
          </div>

          <!-- Markdown body: Discovery / Define / Results -->
          <div class="content-section prose">
            <Content />
          </div>

        </div>
      </div>
    </section>

    <!-- ── DIVIDER — olive → cream-light ────────────────────────── -->
    <Divider from="olive" to="creamLight" direction="left-up" />

    <!-- ── FOOTER — cream variant ───────────────────────────────── -->
    <Footer theme="cream" />

  </body>
</html>

<style>
  /* ── Body / page bg ──────────────────────────────────────────── */
  .case-body {
    background-color: var(--color-cream-400);
    color: var(--color-olive-500);
    -webkit-font-smoothing: antialiased;
  }

  /* ── Case hero (cream-500 bg) ────────────────────────────────── */
  .case-header {
    background-color: var(--color-cream-500);
  }

  .case-hero {
    padding: 24px 0 96px;
    background-color: var(--color-cream-400);
    color: var(--color-olive-500);
  }

  /* Title — Lilita One 500, olive-300 */
  .case-title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(32px, 4.8vw, 56px);
    letter-spacing: -1.5px;
    margin: 24px 0 56px;
    color: var(--color-olive-300);
    display: inline-block;
  }

  /* Two-column grid: meta left, image right */
  .case-grid {
    display: grid;
    grid-template-columns: 1fr 1.3fr;
    gap: 64px;
    align-items: start;
  }

  /* Meta sections (Role, Description, Platform…) */
  .case-section {
    margin-bottom: 24px;
  }
  .case-section h3 {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 20px;
    letter-spacing: -0.2px;
    margin: 0 0 8px;
    color: var(--color-olive-400);
  }
  .case-section p,
  .case-section li {
    font-family: 'Abel', sans-serif;
    font-weight: 400;
    font-size: 16px;
    line-height: 1.65;
    color: var(--color-olive-400);
    margin: 0 0 10px;
    letter-spacing: 0.05px;
  }

  .case-mockups {
    position: relative;
    min-height: 420px;
  }

  /* ── Olive body ──────────────────────────────────────────────── */
  .case-olive {
    padding: 80px 0 96px;
  }

  /* Width cap matching the design (1000px within the 1280px container) */
  .case-olive-inner {
    width: 1000px;
    max-width: 100%;
  }

  /* Section headings inside olive: Lilita One 800, cream-400 */
  .olive-heading {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(28px, 3.6vw, 40px);
    letter-spacing: -0.8px;
    margin: 0 0 40px;
    color: var(--color-cream-400);
    text-align: center;
  }

  /* "The process" heading is left-aligned */
  .process-heading {
    text-align: left;
    margin-top: 80px;
  }

  .delivery-images {
    display: flex;
    flex-direction: column;
    gap: 24px;
    max-width: 1100px;
    margin-inline: auto;
  }

  /* ── Prose (markdown: Discovery / Define / Results) ──────────── */
  .content-section {
    margin-top: 64px;
    width: 1000px;
    max-width: 100%;
  }

  .prose :global(h3) {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 22px;
    letter-spacing: -0.2px;
    margin: 24px 0 6px;
    color: var(--color-cream-400);
  }

  .prose :global(h4) {
    font-family: 'Abel', sans-serif;
    font-weight: 700;
    font-size: 18px;
    margin-top: 16px;
    margin-bottom: 6px;
    color: var(--color-cream-400);
  }

  .prose :global(p) {
    font-family: 'Abel', sans-serif;
    font-weight: 400;
    font-size: 16px;
    line-height: 1.7;
    color: var(--color-cream-400);
    letter-spacing: 0.05px;
    margin: 0 0 12px;
    max-width: none;
  }

  .prose :global(ul) {
    padding-left: 20px;
    list-style: disc;
    margin-bottom: 12px;
  }
  .prose :global(ul li) {
    color: var(--color-cream-400);
    font-family: 'Abel', sans-serif;
    font-weight: 400;
    font-size: 16px;
    line-height: 1.65;
    margin-bottom: 6px;
  }

  .prose :global(a) {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  /* ── Responsive ──────────────────────────────────────────────── */
  @media (max-width: 900px) {
    .case-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }
    .case-mockups { min-height: 0; }
    .case-olive-inner { width: 100%; }
    .content-section { width: 100%; }
  }
</style>
