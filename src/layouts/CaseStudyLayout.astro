---
/**
 * CaseStudyLayout — wraps every case study page.
 *
 * Page structure (matching the design prototype):
 *   [cream-500]  Nav (light) + case-hero: title + two-column grid (meta | image)
 *   [diagonal]   cream → olive
 *   [olive]      "Final production" h2 + images
 *                "The process" h2 + process diagram + BXT paragraph
 *                ContentSection: Discovery / Define / Results
 *   [diagonal]   olive → cream-light
 *   [cream-300]  Footer (cream variant)
 */
import Nav from '../components/Nav.astro';
import Divider from '../components/Divider.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
import type { CollectionEntry } from 'astro:content';

interface Props {
  entry: CollectionEntry<'projects'>;
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const d = entry.data;

// Meta rows to display — omit undefined fields
const metaSections: { label: string; body: string | string[] }[] = [
  { label: 'Role', body: [d.role] },
  ...(d.platform ? [{ label: 'Platform', body: [d.platform] }] : []),
  ...(d.workDone ? [{ label: 'Work done', body: [d.workDone] }] : []),
  ...(d.timeframe ? [{ label: 'Timeframe', body: [d.timeframe] }] : []),
  ...(d.award ? [{ label: 'Awards', body: [d.award] }] : []),
];

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

// Groups heroLeftSection body items into paragraphs and bullet lists.
// Items starting with ** are treated as list items.
type BodyGroup =
  | { type: 'p';    text: string }
  | { type: 'list'; items: string[] };

function groupBody(body: string[]): BodyGroup[] {
  const groups: BodyGroup[] = [];
  let currentList: string[] | null = null;
  for (const item of body) {
    if (item.startsWith('**')) {
      if (!currentList) {
        currentList = [];
        groups.push({ type: 'list', items: currentList });
      }
      currentList.push(item);
    } else {
      currentList = null;
      groups.push({ type: 'p', text: item });
    }
  }
  return groups;
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{d.title} — Christopher Teves</title>
    <meta name="description" content={d.description ?? `${d.title} — Case study by Christopher Teves`} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  </head>

  <body class="case-body">

    <!-- ── STICKY NAV — outside header so sticky spans full page ── -->
    <Nav theme="light" />

    <!-- ── CREAM HEADER ─────────────────────────────────────────── -->
    <header class="case-header">

      <section class="case-hero">
        <div class={`container${d.heroImageLarge ? ' container--wide' : ''}`}>

          <h1 class="case-title">{d.title}</h1>

          <div class={`case-grid${d.heroImageLarge ? ' case-grid--large-image' : ''}`}>
            <!-- Left: meta sections or custom hero content -->
            <div class="case-meta">
              {d.hideMetaSections && d.heroLeftSections
                ? d.heroLeftSections.map((section: { heading: string; body: string[] }) => (
                    <div class="case-section hero-left-section">
                      <h3 class="hero-left-heading">{section.heading}</h3>
                      {groupBody(section.body).map((block: BodyGroup) =>
                        block.type === 'p'
                          ? <p set:html={block.text.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')} />
                          : <ul class="hero-left-list">
                              {block.items.map((item: string) => (
                                <li set:html={item.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')} />
                              ))}
                            </ul>
                      )}
                    </div>
                  ))
                : metaSections.map(section => (
                    <div class="case-section">
                      <h3>{section.label}</h3>
                      {Array.isArray(section.body)
                        ? section.body.map((p: string) => (
                            <p>
                              {section.label === 'Awards' && d.awardUrl
                                ? <a href={d.awardUrl} target="_blank" rel="noopener noreferrer" style="text-decoration:underline;text-underline-offset:3px;">{p}</a>
                                : p
                              }
                            </p>
                          ))
                        : <p>{section.body}</p>
                      }
                    </div>
                  ))
              }
            </div>

            <!-- Right: hero image -->
            <div class="case-mockups">
              {d.heroImage && (
                <div>
                  <img
                    src={`${import.meta.env.BASE_URL}${d.heroImage}`}
                    alt={`${d.title} screens`}
                    class="lightbox-trigger"
                    style="display:block;width:100%;height:auto;cursor:zoom-in;"
                  />
                  {d.award && (
                    <div style="margin-top:16px;display:flex;justify-content:center;">
                      {d.awardUrl ? (
                        <a href={d.awardUrl} target="_blank" rel="noopener noreferrer">
                          <img
                            src={`${import.meta.env.BASE_URL}/images/red-dot.png`}
                            alt="Red Dot Design Award"
                            style="display:block;width:280px;height:auto;"
                          />
                        </a>
                      ) : (
                        <img
                          src={`${import.meta.env.BASE_URL}/images/red-dot.png`}
                          alt="Red Dot Design Award"
                          style="display:block;width:280px;height:auto;"
                        />
                      )}
                    </div>
                  )}
                </div>
              )}
            </div>
          </div>

          <!-- Markdown body rendered below the hero grid -->
          <div class="content-section prose">
            <Content />
          </div>

        </div>
      </section>
    </header>

    <!-- ── DIVIDER — cream → olive ──────────────────────────────── -->
    <Divider from="cream" to="olive500" direction="left-up" />

    <!-- ── OLIVE BODY ───────────────────────────────────────────── -->
    <section class="section--olive case-olive">
      <div class="container">
        <div class="case-olive-inner">

          <!-- Final production -->
          {d.finalProductionImages && d.finalProductionImages.length > 0 && (
            <div class="delivery-section">
              {d.finalProductionSideBySide ? (
                /* Side-by-side: text left, image right */
                <div class="delivery-sidebyside">
                  <div class="delivery-text">
                    <h2 class="olive-heading">{d.finalProductionTitle ?? 'Final production'}</h2>
                    {d.finalProductionText?.map((p: string) => <p class="delivery-p">{p}</p>)}
                  </div>
                  <div class="delivery-image-col">
                    <img
                      src={`${import.meta.env.BASE_URL}${d.finalProductionImages[0]}`}
                      alt={`${d.title} — final production`}
                      class="lightbox-trigger"
                      style="display:block;width:100%;height:auto;cursor:zoom-in;"
                    />
                  </div>
                </div>
              ) : (
                /* Default: stacked */
                <>
                  <h2 class="olive-heading">{d.finalProductionTitle ?? 'Final production'}</h2>
                  <div class="delivery-images">
                    {d.finalProductionImages.map((src: string, i: number) => (
                      <img
                        src={`${import.meta.env.BASE_URL}${src}`}
                        alt={`${d.title} — final production ${i + 1}`}
                        class="lightbox-trigger"
                        style="display:block;width:100%;height:auto;cursor:zoom-in;"
                      />
                    ))}
                  </div>
                  {d.finalProductionText && d.finalProductionText.length > 0 && (
                    <div class="delivery-body">
                      {d.finalProductionText.map((item: string) =>
                        item.trimStart().startsWith('<ul')
                          ? <Fragment set:html={item} />
                          : <p set:html={item.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')} />
                      )}
                    </div>
                  )}
                </>
              )}
            </div>
          )}

          <!-- The process -->
          <div class="process-section">
            {!d.hideProcessHeading && (
              <h2 class="olive-heading process-heading">The process</h2>
            )}

            {d.processImage && (
              <div style="width:100%;margin-bottom:0;">
                <img
                  src={`${import.meta.env.BASE_URL}${d.processImage}`}
                  alt={`${d.title} — process diagram`}
                  style="display:block;width:100%;height:auto;"
                />
              </div>
            )}

            {d.processNote && (
              <p class="process-note">{d.processNote}</p>
            )}
          </div>

          <!-- Competitor image — shown before Discovery if present -->
          {d.competitorImage && (
            <div class="competitor-image">
              <img
                src={`${import.meta.env.BASE_URL}${d.competitorImage}`}
                alt={`${d.title} — competitor analysis`}
                style="display:block;width:100%;height:auto;"
              />
            </div>
          )}

        </div>
      </div>
    </section>

    <!-- ── DIVIDER — olive → cream-light ────────────────────────── -->
    <Divider from="olive500" to="creamLight" direction="left-up" />

    <!-- ── FOOTER — cream variant ───────────────────────────────── -->
    <Footer theme="cream" />

    <!-- ── LIGHTBOX ─────────────────────────────────────────────── -->
    <div id="lightbox" aria-modal="true" role="dialog" aria-label="Image lightbox">
      <button id="lightbox-close" aria-label="Close lightbox">✕</button>
      <img id="lightbox-img" src="" alt="" />
    </div>

  </body>
</html>

<style>
  /* ── Body / page bg ──────────────────────────────────────────── */
  .case-body {
    background-color: var(--color-cream-400);
    color: var(--color-olive-600);
    -webkit-font-smoothing: antialiased;
  }

  /* ── Case hero (cream-500 bg) ────────────────────────────────── */
  .case-header {
    background-color: var(--color-cream-500);
  }

  .case-hero {
    padding: 24px 0 96px;
    background-color: var(--color-cream-400);
    color: var(--color-olive-600);
  }

  /* Title — Lilita One 500, olive-300 */
  .case-title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(32px, 4.8vw, 56px);
    letter-spacing: -1.5px;
    margin: 24px 0 56px;
    color: var(--color-olive-300);
    display: inline-block;
  }

  /* Wider container for Design Systems page only */
  .container--wide {
    max-width: 1600px;
  }

  /* Two-column grid: meta left, image right */
  .case-grid {
    display: grid;
    grid-template-columns: 1fr 1.3fr;
    gap: 64px;
    align-items: start;
  }
  .case-grid--large-image {
    grid-template-columns: 1fr 3fr;
    gap: 48px;
  }

  /* Wider left column for large-image layout (Design Systems) */
  .case-grid--large-image .case-meta {
    min-width: 500px;
  }

  /* Meta sections (Role, Description, Platform…) */
  .case-section {
    margin-bottom: 24px;
  }
  .case-section h3 {
    font-family: 'Abel', sans-serif;
    font-weight: 700;
    font-size: 20px;
    letter-spacing: -0.2px;
    margin: 0 0 8px;
    color: var(--color-olive-500);
  }

  /* Hero left sections (Overview / Challenges style) */
  .hero-left-section {
    margin-bottom: 32px;
  }
  .hero-left-section h3.hero-left-heading {
    font-family: 'Abel', sans-serif;
    font-weight: 700;
    font-size: 22px;
    letter-spacing: -0.3px;
    margin: 0 0 14px;
    color: var(--color-olive-500);
  }
  .hero-left-section p {
    font-family: 'Abel', sans-serif;
    font-weight: 400;
    font-size: 15px;
    line-height: 1.65;
    color: var(--color-olive-600);
    margin: 0 0 10px;
  }
  .hero-left-section p strong {
    font-weight: 700;
    color: var(--color-olive-500);
  }

  .hero-left-list {
    list-style: disc;
    padding-left: 20px;
    margin: 8px 0 12px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .hero-left-list li {
    font-family: 'Abel', sans-serif;
    font-weight: 400;
    font-size: 15px;
    line-height: 1.65;
    color: var(--color-olive-600);
  }
  .hero-left-list li strong {
    font-weight: 700;
    color: var(--color-olive-500);
  }
  .case-section p,
  .case-section li {
    font-family: 'Abel', sans-serif;
    font-weight: 400;
    font-size: 16px;
    line-height: 1.65;
    color: var(--color-olive-600);
    margin: 0 0 10px;
    letter-spacing: 0.05px;
  }

  .case-mockups {
    position: relative;
    min-height: 420px;
  }

  /* ── Olive body ──────────────────────────────────────────────── */
  .case-olive {
    padding: 80px 0 96px;
    background-color: var(--color-olive-500);
  }

  /* Width cap matching the design (1000px within the 1280px container) */
  .case-olive-inner {
    width: 1000px;
    max-width: 100%;
    margin-inline: auto;
  }

  /* Section headings inside olive: Lilita One 800, cream-400 */
  .olive-heading {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(28px, 3.6vw, 40px);
    letter-spacing: -0.8px;
    margin: 0 0 40px;
    color: var(--color-cream-400);
    text-align: left;
  }

  /* "The process" heading — left-aligned like the content */
  .process-heading {
    text-align: left;
    margin-top: 80px;
  }

  /* Text block below stacked final production images */
  .delivery-body {
    margin-top: 40px;
    max-width: 800px;
  }
  .delivery-body p {
    font-family: 'Abel', sans-serif;
    font-weight: 400;
    font-size: 16px;
    line-height: 1.7;
    color: var(--color-cream-400);
    margin-bottom: 16px;
  }
  .delivery-body :global(ul) {
    margin: 8px 0 16px 0;
    padding-left: 20px;
    list-style: disc;
  }
  .delivery-body :global(ul li) {
    font-family: 'Abel', sans-serif;
    font-size: 16px;
    line-height: 1.7;
    color: var(--color-cream-400);
    margin-bottom: 10px;
    list-style: disc;
  }

  .delivery-images {
    display: flex;
    flex-direction: column;
    gap: 24px;
    max-width: 1100px;
    margin-inline: auto;
  }

  /* Allow side-by-side section to use full container width, centred */
  .delivery-section {
    width: 100%;
    max-width: 1280px;
    margin-inline: auto;
  }

  /* Side-by-side delivery layout */
  .delivery-sidebyside {
    display: grid;
    grid-template-columns: 42fr 58fr;
    gap: 56px;
    align-items: start;
  }
  .delivery-text .olive-heading {
    margin-bottom: 24px;
  }
  .delivery-p {
    font-family: 'Abel', sans-serif;
    font-weight: 400;
    font-size: 16px;
    line-height: 1.7;
    color: var(--color-cream-400);
    margin-bottom: 16px;
  }
  .delivery-p:last-child {
    margin-bottom: 0;
  }
  .delivery-image-col img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 4px;
    margin: 0;
  }

  @media (max-width: 900px) {
    .delivery-sidebyside {
      grid-template-columns: 1fr;
      gap: 32px;
    }
  }

  /* ── Process note (BXT paragraph below process image) ───────── */
  .process-note {
    font-family: 'Abel', sans-serif;
    font-weight: 400;
    font-size: 16px;
    line-height: 1.7;
    color: var(--color-cream-400);
    margin: 32px 0 0;
    text-align: left;
  }

  /* ── Competitor image ────────────────────────────────────────── */
  .competitor-image {
    width: 1000px;
    max-width: 100%;
    margin: 64px auto 0;
  }

  /* ── Prose (markdown: Discovery / Define / Results) ──────────── */
  .content-section {
    margin-top: 64px;
    width: 1000px;
    max-width: 100%;
  }

  .prose :global(h2) {
    font-family: 'Abel', sans-serif;
    font-weight: 700;
    font-size: 26px;
    letter-spacing: -0.3px;
    margin: 36px 0 10px;
    color: var(--color-olive-500);
    text-align: left;
  }

  .prose :global(h3) {
    font-family: 'Abel', sans-serif;
    font-weight: 700;
    font-size: 22px;
    letter-spacing: -0.2px;
    margin: 24px 0 6px;
    color: var(--color-olive-500);
    text-align: left;
  }

  .prose :global(h4) {
    font-family: 'Abel', sans-serif;
    font-weight: 700;
    font-size: 18px;
    margin-top: 16px;
    margin-bottom: 6px;
    color: var(--color-olive-500);
  }

  .prose :global(p) {
    font-family: 'Abel', sans-serif;
    font-weight: 400;
    font-size: 16px;
    line-height: 1.7;
    color: var(--color-olive-600);
    letter-spacing: 0.05px;
    margin: 0 0 12px;
    max-width: none;
  }

  .prose :global(blockquote) {
    margin: 20px 0 24px;
    padding: 12px 20px;
    border-left: 3px solid var(--color-olive-400);
    background: transparent;
  }
  .prose :global(blockquote p) {
    font-style: italic;
    font-weight: 700;
    font-size: 16px;
    line-height: 1.65;
    color: var(--color-olive-600);
    margin: 0;
  }

  .prose :global(img) {
    display: block;
    width: 100%;
    height: auto;
    margin: 24px 0;
    border-radius: 4px;
  }

  .prose :global(ul) {
    padding-left: 20px;
    list-style: disc;
    margin-bottom: 12px;
    text-align: left;
  }
  .prose :global(ul li) {
    color: var(--color-olive-600);
    font-family: 'Abel', sans-serif;
    font-weight: 400;
    font-size: 16px;
    line-height: 1.65;
    margin-bottom: 6px;
  }

  .prose :global(a) {
    text-decoration: underline;
    text-underline-offset: 3px;
    color: var(--color-olive-500);
  }

  /* ── Responsive ──────────────────────────────────────────────── */
  @media (max-width: 900px) {
    .case-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }
    .case-grid--large-image .case-meta { min-width: 0; }
    .case-mockups { min-height: 0; }
    .case-olive-inner { width: 100%; }
    .content-section { width: 100%; }
  }

  /* ── Lightbox ────────────────────────────────────────────────── */
  #lightbox {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 1000;
    background: rgba(0, 0, 0, 0.88);
    align-items: center;
    justify-content: center;
    padding: 24px;
    cursor: zoom-out;
  }
  #lightbox.is-open {
    display: flex;
  }
  #lightbox-img {
    max-width: 90vw;
    max-height: 90vh;
    width: auto;
    height: auto;
    object-fit: contain;
    border-radius: 4px;
    box-shadow: 0 24px 80px rgba(0, 0, 0, 0.6);
    cursor: default;
    animation: lb-in 0.2s ease;
  }
  @keyframes lb-in {
    from { opacity: 0; transform: scale(0.96); }
    to   { opacity: 1; transform: scale(1); }
  }
  #lightbox-close {
    position: absolute;
    top: 20px;
    right: 24px;
    background: none;
    border: none;
    color: #fff;
    font-size: 24px;
    line-height: 1;
    cursor: pointer;
    opacity: 0.7;
    transition: opacity 0.15s ease;
    padding: 4px 8px;
  }
  #lightbox-close:hover { opacity: 1; }
</style>

<script>
  const lightbox    = document.getElementById('lightbox');
  const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement | null;
  const closeBtn    = document.getElementById('lightbox-close');
  const triggers = document.querySelectorAll<HTMLImageElement>('.lightbox-trigger, .prose img');

  // Give prose images a zoom cursor
  document.querySelectorAll<HTMLImageElement>('.prose img').forEach(img => {
    img.style.cursor = 'zoom-in';
  });

  const open = (img: HTMLImageElement) => {
    if (!lightbox || !lightboxImg) return;
    lightboxImg.src = img.src;
    lightboxImg.alt = img.alt;
    lightbox.classList.add('is-open');
    document.body.style.overflow = 'hidden';
  };

  const close = () => {
    lightbox?.classList.remove('is-open');
    document.body.style.overflow = '';
  };

  triggers.forEach(img => img.addEventListener('click', () => open(img)));
  closeBtn?.addEventListener('click', (e) => { e.stopPropagation(); close(); });
  lightbox?.addEventListener('click', close);
  lightboxImg?.addEventListener('click', (e) => e.stopPropagation());
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') close(); });
</script>
