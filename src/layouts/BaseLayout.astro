---
/**
 * BaseLayout — shared <head>, Nav, and page wrapper.
 *
 * navTheme: passed down to Nav.
 *   "dark"  → Nav on olive background (homepage hero, default)
 *   "light" → Nav on cream background (case studies)
 */
import Nav from '../components/Nav.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  navTheme?: 'dark' | 'light';
  ogImage?: string;
}

const {
  title,
  description = 'UX/UI Designer — Christopher Teves',
  navTheme = 'dark',
  ogImage = '/images/og-default.png',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary meta -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site)} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Fonts preconnect (speeds up Google Fonts load) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  </head>

  <body>
    <Nav theme={navTheme} />
    <main>
      <slot />
    </main>
  </body>
</html>
