---
/**
 * Footer — cream variant (homepage) or olive variant (case studies).
 * theme="cream" → cream-300 bg, olive text (default, homepage)
 * theme="olive" → olive-400 bg, cream text (case study pages)
 */
import { site } from '../config/site';

interface Props {
  theme?: 'cream' | 'olive';
}
const { theme = 'cream' } = Astro.props;
---

<footer class={`footer footer--${theme}`}>
  <div class="container footer__inner">

    <div class="footer__col footer__col--brand">
      <span class="footer__wordmark">{site.name}</span>
    </div>

    <div class="footer__col footer__col--nav">
      <nav aria-label="Footer navigation">
        <ul role="list">
          <li><a href="/christopher-teves.github.io/#works">Portfolio</a></li>
          <li><a href="/christopher-teves.github.io/stuff">Stuff</a></li>
        </ul>
      </nav>
    </div>

    <div class="footer__col footer__col--contact">
      <div class="footer__contact">
        <a href={`mailto:${site.email}`}>{site.email}</a>
        <span>{site.phone}</span>
        <span>{site.location}</span>
      </div>
      <a
        href={site.linkedin}
        target="_blank"
        rel="noopener noreferrer"
        class="footer__linkedin"
        aria-label="LinkedIn profile"
      ><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.225 0z"/></svg></a>
    </div>

  </div>
</footer>

<style>
  .footer {
    padding: 72px 0 56px;
  }

  /* Theme variants */
  .footer--cream {
    background-color: var(--color-cream-300);
    color: var(--color-olive-500);
  }
  .footer--olive {
    background-color: var(--color-surface-inverse);
    color: var(--color-cream-400);
  }

  .footer__inner {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1.2fr;
    gap: 56px;
    align-items: start;
  }

  /* Wordmark */
  .footer__wordmark {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 32px;
    line-height: 1;
    letter-spacing: -1px;
    display: inline-block;
  }
  .footer--cream .footer__wordmark { color: var(--color-olive-500); }
  .footer--olive .footer__wordmark { color: var(--color-cream-400); }

  /* Nav links */
  .footer__col--nav ul {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .footer__col--nav a {
    font-family: 'Abel', sans-serif;
    font-weight: 400;
    font-size: 15px;
    line-height: 1.6;
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: opacity 0.15s ease;
  }
  .footer__col--nav a:hover { opacity: 0.6; }
  .footer--cream .footer__col--nav a { color: var(--color-olive-500); }
  .footer--olive .footer__col--nav a { color: var(--color-cream-400); }

  /* Contact */
  .footer__contact {
    display: flex;
    flex-direction: column;
    gap: 2px;
    font-family: 'Abel', sans-serif;
    font-weight: 400;
    font-size: 15px;
    line-height: 1.7;
  }
  .footer--cream .footer__contact { color: var(--color-olive-500); }
  .footer--olive .footer__contact { color: var(--color-cream-400); }
  .footer__contact a { transition: opacity 0.15s ease; }
  .footer__contact a:hover { opacity: 0.6; }

  /* LinkedIn badge */
  .footer__linkedin {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    margin-top: 12px;
    transition: opacity 0.15s ease;
  }
  .footer__linkedin:hover { opacity: 0.6; }
  .footer--cream .footer__linkedin { color: var(--color-olive-500); }
  .footer--olive .footer__linkedin { color: var(--color-cream-400); }

  /* Mobile */
  @media (max-width: 768px) {
    .footer__inner {
      grid-template-columns: 1fr;
      gap: 32px;
    }
    .footer__wordmark { font-size: 24px; }
  }
</style>
