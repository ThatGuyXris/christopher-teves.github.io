---
import { site } from '../config/site';
---

<footer class="footer">
  <div class="footer__inner">

    <div class="footer__top">
      <!-- Name — underlined, large -->
      <a href="/" class="footer__name">{site.name}</a>

      <!-- Nav links -->
      <nav aria-label="Footer navigation">
        <ul class="footer__nav" role="list">
          <li><a href="/#select-works">Portfolio</a></li>
          <li><a href="/stuff">Stuff</a></li>
        </ul>
      </nav>
    </div>

    <div class="footer__bottom">
      <!-- Contact -->
      <div class="footer__contact">
        <a href={`mailto:${site.email}`}>{site.email}</a>
        <span>{site.phone}</span>
        <span>{site.location}</span>
      </div>

      <!-- LinkedIn -->
      <a
        href={site.linkedin}
        target="_blank"
        rel="noopener noreferrer"
        class="footer__linkedin"
        aria-label="LinkedIn profile"
      >
        in
      </a>
    </div>

  </div>
</footer>

<style>
  .footer {
    background-color: var(--color-surface-inverse);
    color: var(--color-text-inverse);
    padding-inline: var(--page-padding-desktop);
    padding-block: 64px 48px;
  }

  .footer__inner {
    width: 100%;
    max-width: var(--content-max-width);
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    gap: 48px;
  }

  /* Top row — name + nav */
  .footer__top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 32px;
  }

  .footer__name {
    font-family: 'Inter', sans-serif;
    font-weight: 700;
    font-size: 20px;
    line-height: 1.2;
    color: var(--color-text-inverse);
    text-decoration: underline;
    text-underline-offset: 4px;
    transition: opacity 0.15s ease;
  }
  .footer__name:hover { opacity: 0.7; }

  .footer__nav {
    display: flex;
    flex-direction: column;
    gap: 8px;
    text-align: right;
  }

  .footer__nav a {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: 12px;
    line-height: 1.58;
    color: var(--color-text-inverse);
    opacity: 0.6;
    transition: opacity 0.15s ease;
  }
  .footer__nav a:hover { opacity: 1; }

  /* Bottom row — contact + linkedin */
  .footer__bottom {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 16px;
  }

  .footer__contact {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .footer__contact a,
  .footer__contact span {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: 12px;
    line-height: 1.58;
    color: var(--color-text-inverse);
    opacity: 0.6;
  }
  .footer__contact a:hover { opacity: 1; }

  .footer__linkedin {
    font-family: 'Inter', sans-serif;
    font-weight: 700;
    font-size: 12px;
    line-height: 1;
    color: var(--color-text-inverse);
    border: 1px solid rgba(232, 229, 219, 0.3);
    padding: 6px 9px;
    transition: border-color 0.15s ease, opacity 0.15s ease;
  }
  .footer__linkedin:hover { border-color: var(--color-text-inverse); }

  /* Mobile */
  @media (max-width: 768px) {
    .footer {
      padding-inline: var(--page-padding-mobile);
      padding-block: 48px 40px;
    }

    .footer__top {
      flex-direction: column;
      gap: 24px;
    }

    .footer__nav {
      text-align: left;
    }

    .footer__bottom {
      flex-direction: column;
      align-items: flex-start;
      gap: 24px;
    }
  }
</style>
