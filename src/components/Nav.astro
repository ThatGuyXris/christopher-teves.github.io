---
/**
 * Nav — transparent, inherits section background colour.
 * theme="dark"  → used on olive sections  (logo uses --color-text-inverse)
 * theme="light" → used on cream sections  (logo uses --color-text-primary)
 */
interface Props {
  theme?: 'dark' | 'light';
}
const { theme = 'dark' } = Astro.props;
---

<nav class={`nav nav--${theme}`} aria-label="Main navigation">
  <div class="nav__inner">
    <a href="/" class="nav__logo">Christopher Teves</a>
    <ul class="nav__links" role="list">
      <li><a href="/#select-works">Portfolio</a></li>
      <li><a href="/stuff">Stuff</a></li>
    </ul>
  </div>
</nav>

<style>
  .nav {
    height: var(--nav-height);
    background: transparent;
    display: flex;
    align-items: center;
    /* Full bleed — let the page container handle inner padding */
    padding-inline: var(--page-padding-desktop);
  }

  .nav__inner {
    width: 100%;
    max-width: var(--content-max-width);
    margin-inline: auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  /* Logo */
  .nav__logo {
    font-family: 'Inter', sans-serif;
    font-weight: 700;
    font-size: 14px;
    line-height: 1;
    letter-spacing: var(--tracking-normal);
    transition: opacity 0.15s ease;
  }
  .nav__logo:hover { opacity: 0.7; }

  .nav--dark  .nav__logo { color: var(--color-text-inverse); }
  .nav--light .nav__logo { color: var(--color-text-primary); }

  /* Links */
  .nav__links {
    display: flex;
    gap: 32px;
  }

  .nav__links a {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: 13px;
    line-height: 1;
    letter-spacing: var(--tracking-normal);
    color: var(--color-text-secondary);
    transition: color 0.15s ease;
  }
  .nav__links a:hover { color: var(--color-text-inverse); }
  .nav--light .nav__links a:hover { color: var(--color-text-primary); }

  /* Mobile */
  @media (max-width: 768px) {
    .nav {
      padding-inline: var(--page-padding-mobile);
    }
    .nav__links {
      gap: 24px;
    }
  }
</style>
