---
/**
 * Nav — transparent, inherits the section's background.
 * theme="dark"  → olive section  (wordmark uses amber-200)
 * theme="light" → cream section  (wordmark uses olive-300)
 */
interface Props {
  theme?: 'dark' | 'light';
}
const { theme = 'dark' } = Astro.props;
---

<nav class={`nav nav--${theme}`} aria-label="Main navigation">
  <div class="nav__inner container">
    <a href="/christopher-teves.github.io/" class="nav__wordmark">Christopher Teves</a>
    <ul class="nav__links" role="list">
      <li><a href="/christopher-teves.github.io/#works" class="nav__link">Portfolio</a></li>
      <li><a href="/christopher-teves.github.io/stuff" class="nav__link">Stuff</a></li>
    </ul>
  </div>
</nav>

<style>
  .nav {
    height: var(--nav-height);
    display: flex;
    align-items: center;
    position: sticky;
    top: 0;
    z-index: 100;
    background: transparent;
    transition: background-color 0.25s ease, backdrop-filter 0.25s ease;
  }

  .nav.is-scrolled {
    background-color: rgba(42, 44, 32, 0.88); /* olive with opacity */
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
  }

  /* Wordmark — Lilita One */
  .nav__wordmark {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 16px;
    line-height: 1;
    letter-spacing: -0.5px;
    white-space: nowrap;
    transition: opacity 0.15s ease;
  }
  .nav__wordmark:hover { opacity: 0.7; }

  .nav--dark  .nav__wordmark { color: var(--color-amber-200); }
  .nav--light .nav__wordmark { color: var(--color-olive-300); }

  /* Links */
  .nav__links {
    display: flex;
    gap: 32px;
  }

  .nav__link {
    font-family: 'Abel', sans-serif;
    font-weight: 600;
    font-size: 15px;
    line-height: 1;
    letter-spacing: 0.2px;
    padding-bottom: 2px;
    transition: text-decoration-color 0.15s ease;
  }
  .nav__link:hover {
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  .nav--dark  .nav__link { color: var(--color-cream-400); opacity: 0.75; }
  .nav--light .nav__link { color: var(--color-olive-400); opacity: 0.75; }

  .nav--dark  .nav__link:hover { opacity: 1; }
  .nav--light .nav__link:hover { opacity: 1; }

  /* Mobile */
  @media (max-width: 768px) {
    .nav__links { gap: 24px; }
    .nav__wordmark { font-size: 14px; }
  }
</style>

<script>
  const nav = document.querySelector('.nav') as HTMLElement | null;
  if (nav) {
    const onScroll = () => {
      nav.classList.toggle('is-scrolled', window.scrollY > 16);
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }
</script>
