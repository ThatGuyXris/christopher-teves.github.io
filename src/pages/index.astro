---
import BaseLayout from '../layouts/BaseLayout.astro';
import Divider from '../components/Divider.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';
import { site } from '../config/site';

const allProjects = await getCollection('projects');
const projects = allProjects.sort((a, b) => a.data.order - b.data.order);

const projectLinks = [
  { slug: 'verisure-automation',  title: 'Verisure Automation' },
  { slug: 'bosch-ebike',          title: 'Bosch eBike' },
  { slug: 'design-systems',       title: 'Design Systems' },
  { slug: 'sinch-conversation-api', title: 'Sinch Conversation API' },
  { slug: 'verisure-innovation',  title: 'Verisure Innovation' },
  { slug: 'draftit',              title: 'Draftit' },
];
---

<BaseLayout
  title="Christopher Teves — UX/UI Designer"
  description={site.heroBio[0]}
  navTheme="dark"
>

  <!-- ═══════════════════════════════════════════════════════════
       HERO — olive bg
       Portrait is absolutely positioned behind the display name.
       Name sits in front (z-index 3), portrait behind (z-index 1).
       ═══════════════════════════════════════════════════════════ -->
  <header class="section--olive">
    <section class="hero">
      <div class="container">
        <div class="hero-stage">

          <!-- Portrait — bleeds behind the name, no frame -->
          <div class="hero-portrait" aria-hidden="false">
            <img
              src="/christopher-teves.github.io/images/portrait_v2.png"
              alt="Portrait of Christopher Teves"
              loading="eager"
            />
          </div>

          <!-- Display name — in front of portrait -->
          <h1 class="hero-name">
            CHRISTOPHER
            <span class="hero-name__teves">TEVES</span>
          </h1>

          <!-- Bio — below/beside name, in front of portrait -->
          <div class="hero-bio">
            {site.heroBio.map(paragraph => (
              <p>{paragraph}</p>
            ))}
          </div>

        </div>
      </div>
    </section>
  </header>

  <!-- ═══════════════════════════════════════════════════════════
       DIVIDER — olive → cream (left-up diagonal)
       ═══════════════════════════════════════════════════════════ -->
  <Divider from="olive" to="cream" direction="left-up" />

  <!-- ═══════════════════════════════════════════════════════════
       SELECT WORKS — cream bg
       Full-width rows: title left, arrow right, dividers between.
       ═══════════════════════════════════════════════════════════ -->
  <section class="section--cream works" id="works">

    <div class="container works-inner">
      <!-- Label -->
      <div class="works-header">
        <div class="works-eyebrow">/Select works</div>
      </div>

      <!-- Project rows -->
      <ul class="works-list" role="list">
        {projectLinks.map(p => (
          <li class="works-item">
            <a href={`/christopher-teves.github.io/portfolio/${p.slug}`} class="works-row">
              <span class="works-title">{p.title}</span>
              <span class="works-arrow">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <line x1="7" y1="17" x2="17" y2="7"/>
                  <polyline points="7 7 17 7 17 17"/>
                </svg>
              </span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════
       DIVIDER — cream → olive (right-up diagonal)
       ═══════════════════════════════════════════════════════════ -->
  <Divider from="cream" to="olive" direction="right-up" />

  <!-- ═══════════════════════════════════════════════════════════
       FACTS — olive bg
       "Facts" italic heading, skills, languages, CTA
       ═══════════════════════════════════════════════════════════ -->
  <section class="section--olive facts">
    <div class="container">

      <h2 class="facts-heading"><em>Facts</em></h2>

      <div class="facts-grid">

        <!-- Skills — pipe-separated inline spans -->
        <div class="facts-col">
          <h4>Skills</h4>
          <div class="facts-skills">
            {site.skills.map((skill, i) => (
              <span>{skill}</span>
            ))}
          </div>
        </div>

        <!-- Languages -->
        <div class="facts-col">
          <h4>Languages</h4>
          <ul class="facts-langs" role="list">
            {site.languages.map(lang => (
              <li>{lang}</li>
            ))}
          </ul>
        </div>

        <!-- CTA -->
        <div class="facts-col facts-cta">
          <h3>{site.ctaHeading}</h3>
          <p>
            {site.ctaBody}
            {' '}
            <a
              href={site.linkedin}
              target="_blank"
              rel="noopener noreferrer"
            >{site.ctaLinkedInLabel}</a>
          </p>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════
       DIVIDER — olive → cream-light (before footer)
       ═══════════════════════════════════════════════════════════ -->
  <Divider from="olive" to="creamLight" direction="left-up" />

  <!-- ═══════════════════════════════════════════════════════════
       FOOTER — cream variant
       ═══════════════════════════════════════════════════════════ -->
  <Footer theme="cream" />

</BaseLayout>

<script>
  // Split each works title into letter spans for wave animation
  document.querySelectorAll('.works-title').forEach(title => {
    const text = title.textContent || '';
    title.innerHTML = text.split('').map((char, i) =>
      char === ' '
        ? `<span class="works-letter" style="--i:${i}" aria-hidden="true">&nbsp;</span>`
        : `<span class="works-letter" style="--i:${i}">${char}</span>`
    ).join('');
  });
</script>

<style>
  /* ── Hero ─────────────────────────────────────────────────────── */
  .hero {
    padding: 56px 0 80px;
    position: relative;
    overflow: hidden;
  }

  /* Stage: portrait + name + bio occupy the same space */
  .hero-stage {
    position: relative;
    min-height: clamp(560px, 70vw, 920px);
  }

  /* Portrait — absolute, bleeds right, sits behind name */
  .hero-portrait {
    position: absolute;
    top: 20px;
    right: -60px;
    bottom: 0;
    width: clamp(480px, 65vw, 860px);
    max-width: 100%;
    z-index: 4;
    pointer-events: none;
    overflow: visible;
  }
  .hero-portrait img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: contain;
    object-position: 50% top;
  }

  /* Display name — Lilita One, amber-200, in front */
  .hero-name {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(64px, 12vw, 184px);
    line-height: 0.92;
    letter-spacing: -2px;
    text-transform: uppercase;
    color: var(--color-amber-200);
    position: relative;
    z-index: 3;
    pointer-events: none;
    margin: 0;
  }

  .hero-name__teves {
    display: block;
    font-size: 0.78em;
  }

  /* Bio — z-index 5 (in front of portrait) */
  .hero-bio {
    position: relative;
    z-index: 5;
    display: flex;
    flex-direction: column;
    gap: 18px;
    max-width: 44ch;
    margin-top: clamp(24px, 3vw, 48px);
  }
  .hero-bio p {
    font-family: 'Abel', sans-serif;
    font-weight: 400;
    font-size: 20px;
    line-height: 1.7;
    color: var(--color-cream-400);
    letter-spacing: 0.1px;
  }

  /* ── Select Works ─────────────────────────────────────────────── */
  .works {
    padding: 96px 0 120px;
    background: var(--color-surface-page);
  }

  .works-inner {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  /* Header: watermark + label stacked */
  .works-header {
    position: relative;
    margin-bottom: 32px;
  }

  /* "/Select works" label */
  .works-eyebrow {
    position: relative;
    font-family: 'Inter', system-ui, sans-serif;
    font-weight: 700;
    font-size: 18px;
    letter-spacing: 0.2px;
    color: var(--color-amber-400);
    line-height: 1;
  }

  /* Project rows */
  .works-list {
    display: flex;
    flex-direction: column;
  }

  .works-item {
    border-bottom: 1px solid var(--color-border-subtle);
  }
  .works-item:first-child {
    border-top: 1px solid var(--color-border-subtle);
  }

  .works-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20px 0;
    text-decoration: none;
    color: var(--color-text-primary);
    transition: opacity 0.2s ease, color 0.2s ease;
  }
  .works-row:hover {
    opacity: 0.6;
    color: var(--color-amber-500);
  }

  .works-title {
    font-family: 'Abel', sans-serif;
    font-weight: 700;
    font-size: clamp(42px, 6vw, 88px);
    text-transform: uppercase;
    color: inherit;
    line-height: 1.1;
    letter-spacing: -0.5px;
    display: flex;
    flex-wrap: wrap;
  }

  .works-letter {
    display: inline-block;
    transition: transform 0.3s ease, color 0.2s ease;
  }

  @keyframes letterWave {
    0%   { transform: translateY(0); }
    40%  { transform: translateY(-10px); }
    70%  { transform: translateY(3px); }
    100% { transform: translateY(0); }
  }

  .works-row:hover .works-letter {
    animation: letterWave 0.6s ease forwards;
    animation-delay: calc(var(--i) * 0.03s);
  }

  .works-arrow {
    display: flex;
    align-items: center;
    color: inherit;
    flex-shrink: 0;
    margin-left: 24px;
  }
  .works-arrow svg {
    width: 42px;
    height: 42px;
  }

  /* ── Facts ────────────────────────────────────────────────────── */
  .facts {
    padding: 96px 0 120px;
  }

  .facts-heading {
    font-family: var(--font-serif);
    font-style: italic;
    font-weight: 400;
    font-size: 56px;
    letter-spacing: -1.5px;
    margin: 0 0 56px;
    color: var(--color-cream-400);
  }
  .facts-heading em {
    color: var(--color-amber-200);
    font-style: inherit;
  }

  .facts-grid {
    display: grid;
    grid-template-columns: 1.5fr 0.8fr 1.2fr;
    gap: 56px;
    align-items: start;
  }

  .facts-col h4 {
    font-family: 'Abel', sans-serif;
    font-weight: 700;
    font-size: 20px;
    line-height: 1;
    margin: 0 0 18px;
    color: var(--color-cream-400);
    letter-spacing: 0.2px;
  }

  /* Skills — pipe-separated inline spans */
  .facts-skills {
    font-family: 'Abel', sans-serif;
    font-weight: 400;
    font-size: 16px;
    line-height: 1.7;
    color: var(--color-cream-400);
    letter-spacing: 0.1px;
  }
  .facts-skills span::after {
    content: ' | ';
    color: var(--color-cream-500);
  }
  .facts-skills span:last-child::after { content: ''; }

  /* Languages */
  .facts-langs {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .facts-langs li {
    font-family: 'Abel', sans-serif;
    font-weight: 400;
    font-size: 17px;
    line-height: 1.6;
    color: var(--color-cream-400);
  }

  /* CTA */
  .facts-cta h3 {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 22px;
    margin: 0 0 12px;
    color: var(--color-cream-400);
    letter-spacing: -0.4px;
  }
  .facts-cta p {
    font-family: 'Abel', sans-serif;
    font-weight: 400;
    font-size: 17px;
    line-height: 1.6;
    margin: 0;
    color: var(--color-cream-400);
  }
  .facts-cta a {
    text-decoration: underline;
    text-underline-offset: 3px;
    color: var(--color-cream-400);
    transition: opacity 0.15s ease;
  }
  .facts-cta a:hover { opacity: 0.7; }

  /* ── Responsive ───────────────────────────────────────────────── */
  @media (max-width: 900px) {
    .hero-portrait {
      position: relative;
      top: auto;
      right: auto;
      width: 80%;
      margin: 24px auto 0;
    }
    .hero-name { font-size: 64px; }
    .hero-stage { min-height: 0; }

    .works-inner {
      grid-template-columns: 1fr;
      gap: 32px;
    }
    .works-eyebrow { font-size: 40px; }

    .facts-grid { grid-template-columns: 1fr; gap: 32px; }
    .facts-heading { font-size: 40px; }
  }
</style>
