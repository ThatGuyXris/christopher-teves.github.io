---
import BaseLayout from '../layouts/BaseLayout.astro';

// Read trends.json from the public folder
// Falls back to empty array if file doesn't exist yet
let trends: any[] = [];
try {
  const raw = await import('../../public/trends.json');
  trends = raw.default || [];
} catch {
  trends = [];
}

const categoryColors: Record<string, string> = {
  'UX/UI Design':   'var(--color-olive-400)',
  'Product Design': 'var(--color-olive-500)',
  'AI & Tech':      'var(--color-amber-400)',
  'Design Tools':   'var(--color-olive-300)',
};

const lastUpdated = trends.length > 0 && trends[0].date
  ? new Date(trends[0].date).toLocaleDateString('en-GB', {
      weekday: 'long', year: 'numeric', month: 'long', day: 'numeric'
    })
  : null;
---

<BaseLayout
  title="Trends — Christopher Teves"
  description="Daily UX/UI, Product Design and AI trends curated by Christopher Teves."
  navTheme="light"
>
  <div class="trends-page">

    <!-- Page header -->
    <header class="page-header">
      <div class="page-header__inner">
        <p class="page-header__label">Daily Digest</p>
        <h1 class="page-header__title">Design & Tech Radar</h1>
        <p class="page-header__description">
          UX/UI, Product Design, AI and Design Tools — curated daily by an AI agent and delivered fresh every morning.
        </p>
        {lastUpdated && (
          <p class="page-header__date">Last updated: {lastUpdated}</p>
        )}
      </div>
    </header>

    <!-- Trend cards -->
    <section class="trends-section">
      <div class="trends-inner">

        {trends.length === 0 ? (
          <div class="empty-state">
            <p class="empty-state__text">The first digest will arrive tomorrow morning.</p>
          </div>
        ) : (
          <ol class="trends-list">
            {trends.map((trend, index) => {
              const accentColor = categoryColors[trend.category] || 'var(--color-olive-400)';
              return (
                <li class="trend-card">
                  <div class="trend-card__accent" style={`background: ${accentColor}`} />
                  <div class="trend-card__body">
                    <div class="trend-card__meta">
                      <span class="trend-card__category" style={`color: ${accentColor}`}>
                        {trend.category}
                      </span>
                      <span class="trend-card__index">0{index + 1}</span>
                    </div>
                    <h2 class="trend-card__title">{trend.title}</h2>
                    <div class="trend-card__section">
                      <p class="trend-card__section-label">Why it matters</p>
                      <p class="trend-card__text">{trend.why_it_matters}</p>
                    </div>
                    <div class="trend-card__section">
                      <p class="trend-card__section-label">What's happening</p>
                      <p class="trend-card__text">{trend.whats_happening}</p>
                    </div>
                    <a
                      href={trend.source_url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="trend-card__source"
                    >
                      {trend.source_name} ↗
                    </a>
                  </div>
                </li>
              );
            })}
          </ol>
        )}

      </div>
    </section>

  </div>
</BaseLayout>

<style>
  /* ── Page layout ─────────────────────────────────────────────── */
  .trends-page {
    background: var(--color-surface-page);
    min-height: 100vh;
  }

  /* ── Header ──────────────────────────────────────────────────── */
  .page-header {
    background: var(--color-surface-inverse);
    padding: calc(var(--nav-height) + 64px) var(--page-padding-desktop) 64px;
  }

  .page-header__inner {
    max-width: var(--content-max-width);
    margin: 0 auto;
  }

  .page-header__label {
    font: var(--font-label-small);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-amber-400);
    margin: 0 0 16px;
  }

  .page-header__title {
    font: var(--font-display-medium);
    color: var(--color-text-inverse);
    letter-spacing: var(--tracking-display);
    margin: 0 0 20px;
    line-height: 0.96;
  }

  .page-header__description {
    font: var(--font-body-large);
    color: var(--color-olive-200);
    max-width: 560px;
    margin: 0 0 12px;
  }

  .page-header__date {
    font: var(--font-body-small);
    color: var(--color-olive-300);
    margin: 0;
  }

  /* ── Trends section ──────────────────────────────────────────── */
  .trends-section {
    padding: 64px var(--page-padding-desktop) 96px;
  }

  .trends-inner {
    max-width: var(--content-max-width);
    margin: 0 auto;
  }

  /* ── Trends list ─────────────────────────────────────────────── */
  .trends-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  /* ── Trend card ──────────────────────────────────────────────── */
  .trend-card {
    display: flex;
    background: var(--color-surface-secondary);
    border: 1px solid var(--color-border-subtle);
    transition: border-color 0.2s ease;
  }

  .trend-card:hover {
    border-color: var(--color-border-default);
  }

  .trend-card__accent {
    width: 4px;
    flex-shrink: 0;
  }

  .trend-card__body {
    padding: 32px 36px;
    flex: 1;
  }

  .trend-card__meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 12px;
  }

  .trend-card__category {
    font: var(--font-label-small);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
  }

  .trend-card__index {
    font: var(--font-label-small);
    letter-spacing: var(--tracking-wide);
    color: var(--color-text-tertiary);
  }

  .trend-card__title {
    font: var(--font-heading-3);
    color: var(--color-text-primary);
    letter-spacing: var(--tracking-tight);
    margin: 0 0 28px;
  }

  .trend-card__section {
    margin-bottom: 20px;
  }

  .trend-card__section-label {
    font: var(--font-label-small);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-text-secondary);
    margin: 0 0 6px;
  }

  .trend-card__text {
    font: var(--font-body-medium);
    color: var(--color-text-primary);
    letter-spacing: var(--tracking-normal);
    margin: 0;
  }

  .trend-card__source {
    display: inline-block;
    margin-top: 8px;
    font: var(--font-label-medium);
    color: var(--color-text-secondary);
    text-decoration: none;
    border-bottom: 1px solid var(--color-border-subtle);
    padding-bottom: 1px;
    transition: color 0.15s ease, border-color 0.15s ease;
  }

  .trend-card__source:hover {
    color: var(--color-text-primary);
    border-color: var(--color-border-strong);
  }

  /* ── Empty state ─────────────────────────────────────────────── */
  .empty-state {
    padding: 80px 0;
    text-align: center;
  }

  .empty-state__text {
    font: var(--font-body-large);
    color: var(--color-text-secondary);
  }

  /* ── Responsive ──────────────────────────────────────────────── */
  @media (max-width: 768px) {
    .page-header {
      padding: calc(var(--nav-height) + 40px) var(--page-padding-mobile) 40px;
    }

    .page-header__title {
      font-size: 48px;
    }

    .trends-section {
      padding: 40px var(--page-padding-mobile) 64px;
    }

    .trend-card__body {
      padding: 24px 20px;
    }
  }
</style>
